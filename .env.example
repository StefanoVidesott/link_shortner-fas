# ── Flask app ─────────────────────────────────────────────────────────────────
BASE_URL=http://localhost:5000
LINK_TTL_DAYS=30
CLEANUP_INTERVAL_MINUTES=10

# ── Admin panel ───────────────────────────────────────────────────────────────
# Generate SECRET_KEY with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=REPLACE_WITH_GENERATED_SECRET
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme_admin

# ── Sentry dashboard URL (optional) ──────────────────────────────────────────
# Shown on the Observability page. Leave blank to link to sentry.io generically.
GRAFANA_URL=
PROMETHEUS_URL=
SENTRY_URL=

# ── MySQL ─────────────────────────────────────────────────────────────────────
MYSQL_ROOT_PASSWORD=changeme_root
MYSQL_DATABASE=linkshortener
MYSQL_USER=app
MYSQL_PASSWORD=changeme_app

# ── Grafana ───────────────────────────────────────────────────────────────────
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=changeme_grafana
# Shared secret between Grafana and the image renderer (any non-empty string)
GRAFANA_RENDERER_TOKEN=changeme_renderer

# ── Sentry (optional — leave blank to disable) ────────────────────────────────
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1
